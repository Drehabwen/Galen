{
  "$schema": "https://raw.githubusercontent.com/nicepkg/vscode-tauri/main/schemas/tauri.conf.schema.json",
  "productName": "VIBE Paper",
  "version": "0.1.0",
  "identifier": "com.vibepaper.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VIBE Paper — 医学科研助手",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 550,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
